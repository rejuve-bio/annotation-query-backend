FROM rustlang/rust:nightly
    
RUN rustup install nightly-2026-03-01 && rustup default nightly-2026-03-01

WORKDIR /app

ENV CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
    && rm -rf /var/lib/apt/lists/*

RUN git clone https://github.com/Adam-Vandervorst/PathMap.git /app/PathMap \
    && cd /app/PathMap \
    && cargo build --release

RUN git clone https://github.com/trueagi-io/MORK.git /app/MORK \
    && cd /app/MORK/kernel \
    && cargo build --release
