# ── Docker / Infrastructure ───────────────────────────────────────────────────
DOCKER_HUB_REPO=your-dockerhub-org/annotation-service:latest
APP_PORT=5000
MONGODB_DOCKER_PORT=27017
REDIS_DOCKER_PORT=6380
CADDY_PORT=8090
CADDY_PORT_FORWARD=5000

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/annotation_db

# ── MORK data directories ─────────────────────────────────────────────────────
# Human ACT file directory — must match human.data_dir in config/config.yaml.
# This path is bind-mounted into the container at the same absolute path.
MORK_DATA_DIR=/mnt/hdd_1/biocypher-kg/output/hsa/metta_out_v6

# Fly ACT file directory — uncomment when flybase.act is available.
# FLY_MORK_DATA_DIR=/mnt/hdd_1/biocypher-kg/output/dmel/metta

# ── Auth / Security ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret
SECRET_KEY=change-me-secret-key
SHARED_TOKEN_SECRET=change-me-shared-secret

# ── LLM providers ─────────────────────────────────────────────────────────────
# LLM_MODEL selects the active provider: openai | gemini
# LLM_MODEL=openai
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# ES_URL=https://your-elasticsearch-host:9200
# ES_API_KEY=

# ── Email (optional) ──────────────────────────────────────────────────────────
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=no-reply@example.com
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=no-reply@example.com
# MAIL_USE_TLS=true
# MAIL_USE_SSL=false

# ── Neo4j (legacy, only needed for cypher database type) ─────────────────────
# HUMAN_NEO4J_URI=bolt://localhost:7687
# HUMAN_NEO4J_USERNAME=neo4j
# HUMAN_NEO4J_PASSWORD=
# FLY_NEO4J_URI=bolt://localhost:7688
# FLY_NEO4J_USERNAME=neo4j
# FLY_NEO4J_PASSWORD=

# ── MORK HTTP server (only needed for mork database type) ─────────────────────
# MORK_URL=http://localhost:8080
